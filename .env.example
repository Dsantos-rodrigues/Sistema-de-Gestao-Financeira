# .env.example — template de variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais:
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
# O arquivo .env nunca deve ser commitado no git (já está no .gitignore)

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres        # usuário administrador do banco
POSTGRES_PASSWORD=postgres    # senha do banco — troque em produção!
POSTGRES_DB=financeiro        # nome do banco de dados criado automaticamente

# ─── Backend NestJS ───────────────────────────────────────────────────────────

# URL de conexão usada pelo Prisma para conectar ao banco
# Quando rodando via Docker, o host é o nome do serviço (postgres)
# Quando rodando localmente, o host é localhost
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/financeiro

# Chave secreta usada para assinar e validar os tokens JWT
# Troque por uma string longa e aleatória em produção!
JWT_SECRET=troque_por_uma_chave_secreta_segura

# Porta em que o backend NestJS vai escutar
PORT=3000
